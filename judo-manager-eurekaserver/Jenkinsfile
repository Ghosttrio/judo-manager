pipeline {
    agent any

    stages {
        stage('CLONE') {
            steps {
                script{
                    git 'https://github.com/Ghosttrio/judo-manager.git'
                }
            }
        }
        stage('BUILD'){
            steps{
                script{
                    sh '''
                        cd judo-manager-eurekaserver
                        chmod +x gradlew
                        ./gradlew clean build
                    '''
                }
            }
        }
    }
}